<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.brickbot.daily-brief</string>

    <!-- Wraps `node cli/daily-brief.js` in caffeinate so the system holds awake -->
    <!-- for exactly the script's lifetime. Wakelock releases on script exit.   -->
    <key>ProgramArguments</key>
    <array>
        <string>__HOME__/projects/brickbot/scripts/run-with-wakelock.sh</string>
        <string>/opt/homebrew/bin/node</string>
        <string>__HOME__/projects/brickbot/cli/daily-brief.js</string>
    </array>

    <!-- Single fire at 6:00 AM — separate from `yarn sync`.                      -->
    <!-- Reads existing data/*.json (refreshed by 11 PM sync the night before),   -->
    <!-- scans active project folders for `morning_brief:` frontmatter, writes    -->
    <!-- data/briefs/<today>.json. ~5 sec runtime. Lands ~55 min before the 7 AM  -->
    <!-- Cowork morning-brief task that consumes the brief.                       -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key><integer>6</integer>
        <key>Minute</key><integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>__HOME__/projects/brickbot/local/logs/launchd-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/projects/brickbot/local/logs/launchd-stderr.log</string>

    <key>WorkingDirectory</key>
    <string>__HOME__/projects/brickbot</string>
</dict>
</plist>
