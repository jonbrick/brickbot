###################################################
# Brickbot Environment Configuration
###################################################
# Copy this file to .env and fill in your actual values
# See SETUP.md for detailed setup instructions
# See EXTERNAL_SERVICES_SETUP.md for API credential setup


###################################################
# Core API Credentials
###################################################

# Notion API Token (Required)
# Get from: https://www.notion.so/my-integrations
NOTION_TOKEN=

# Anthropic Claude API Key (Required for AI features)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=
CLAUDE_MAX_TOKENS=
CLAUDE_TEMPERATURE=

###################################################
# Notion Database IDs (Required)
###################################################

# 🚨🚨🚨🚨 START must be changed every year 🚨🚨🚨🚨🚨

# 2026 Notion Database IDs
MONTHS_DATABASE_ID=
NOTION_BLOOD_PRESSURE_DATABASE_ID=
NOTION_BODY_WEIGHT_DATABASE_ID=
NOTION_EVENTS_DATABASE_ID=
NOTION_GOALS_DATABASE_ID=
NOTION_MEDICATIONS_DATABASE_ID=
NOTION_PERSONAL_PRS_DATABASE_ID=
NOTION_WORK_PRS_DATABASE_ID=
NOTION_RELATIONSHIPS_DATABASE_ID=
NOTION_ROCKS_DATABASE_ID=
NOTION_SLEEP_DATABASE_ID=
NOTION_THEMES_DATABASE_ID=
NOTION_TRIPS_DATABASE_ID=
NOTION_VIDEO_GAMES_DATABASE_ID=
NOTION_WORKOUTS_DATABASE_ID=
NOTION_YEARS_DATABASE_ID=
PERSONAL_MONTHLY_PLAN_DATABASE_ID=
PERSONAL_MONTHLY_RECAP_DATABASE_ID=
PERSONAL_WEEK_RETRO_DATABASE_ID=
PERSONAL_WEEK_SUMMARY_DATABASE_ID=
HABITS_WEEK_SUMMARY_DATABASE_ID=
TASKS_DATABASE_ID=
WORK_MONTHLY_PLAN_DATABASE_ID=
WEEKS_DATABASE_ID=
WORK_MONTHLY_RECAP_DATABASE_ID=
WORK_WEEK_RETRO_DATABASE_ID=
WORK_WEEK_SUMMARY__DATABASE_ID=

# 🚨🚨🚨🚨 END must be changed every year 🚨🚨🚨🚨🚨

###################################################
# Google Calendar OAuth (Personal Account)
###################################################

# Required for calendar sync functionality
# Setup: https://console.cloud.google.com/
# Run: yarn tokens:setup to generate REFRESH_TOKEN

PERSONAL_GOOGLE_CLIENT_ID=
PERSONAL_GOOGLE_CLIENT_SECRET=
PERSONAL_GOOGLE_REFRESH_TOKEN=
GOOGLE_REDIRECT_URI=
PLACES_API_KEY=

###################################################
# Google Calendar IDs
###################################################

# Get calendar IDs from Google Calendar settings > Integrate calendar
# Format: xxxxxxxxxxxxx@group.calendar.google.com (or 'primary' for main calendar)

# Main calendars
PERSONAL_MAIN_CALENDAR_ID=
WORK_MAIN_CALENDAR_ID=

# Events & Trips calendars
EVENTS_CALENDAR_ID=
TRIPS_CALENDAR_ID=

WORK_EVENTS_CALENDAR_ID=
WORK_TRIPS_CALENDAR_ID=

# PR calendars
PERSONAL_PRS_CALENDAR_ID=
WORK_PRS_CALENDAR_ID=

# Activity calendars

# Automatically updated from APIs
NORMAL_WAKE_UP_CALENDAR_ID=
SLEEP_IN_CALENDAR_ID=
WORKOUT_CALENDAR_ID=
BODY_WEIGHT_CALENDAR_ID=

# Automatically updated from Notion
BLOOD_PRESSURE_CALENDAR_ID=
MEDICATIONS_CALENDAR_ID=

# Manually updated diet
SOBER_CALENDAR_ID=
DRINKING_CALENDAR_ID=
COOKING_CALENDAR_ID=

# Manually updated exercise
MEDITATION_CALENDAR_ID=

# Manually updated hobbies
READING_CALENDAR_ID=
ART_CALENDAR_ID=
MUSIC_CALENDAR_ID=
CODING_CALENDAR_ID=
VIDEO_GAMES_CALENDAR_ID=

###################################################
# GitHub API (Optional)
###################################################

# Required for GitHub PR and commit tracking
# Get from: https://github.com/settings/tokens
# Required scopes: repo, read:user

GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_WORK_ORG=

###################################################
# Oura Ring API (Optional)
###################################################

# Required for sleep tracking
# Get from: https://cloud.ouraring.com/personal-access-tokens

OURA_TOKEN=

###################################################
# Strava API (Optional)
###################################################

# Required for workout/fitness tracking
# Setup: https://www.strava.com/settings/api
# Run: yarn tokens:setup to complete OAuth flow

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=

# Auto-populated by yarn tokens:setup
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=
STRAVA_TOKEN_EXPIRY=

###################################################
# Steam API (Optional)
###################################################

# Required for gaming activity tracking
# Get API key from: https://steamcommunity.com/dev/apikey
# Find Steam ID from your profile URL

STEAM_URL=

###################################################
# Withings API (Optional)
###################################################

# Required for body weight/metrics tracking
# Setup: https://developer.withings.com/
# Run: yarn tokens:setup to complete OAuth flow

WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_REDIRECT_URI=

# Auto-populated by yarn tokens:setup
WITHINGS_ACCESS_TOKEN=
WITHINGS_REFRESH_TOKEN=
WITHINGS_TOKEN_EXPIRY=

###################################################
# Google Calendar OAuth (Work Account - Optional)
###################################################

# Only needed if tracking work calendar separately
# Same setup process as personal account

WORK_GOOGLE_CLIENT_ID=
WORK_GOOGLE_CLIENT_SECRET=
WORK_GOOGLE_REFRESH_TOKEN=

###################################################
# Apple Notes Configuration (Optional)
###################################################

# Used by sweep-notes command to transform notes into tasks
# No API required - uses AppleScript locally

APPLE_NOTES_FOLDER=
APPLE_NOTES_PROCESSED_TAG=
APPLE_NOTES_BATCH_SIZE=

###################################################
# General Settings (Optional)
###################################################

NODE_ENV=
DEBUG_API_CALLS=
TRACK_COSTS=
ENABLE_CALENDAR_SYNC=

WITHINGS_USER_ID=

# NYC Databases
NYC_MUSEUMS_DATABASE_ID=
NYC_RESTAURANTS_DATABASE_ID=
NYC_TATTOOS_DATABASE_ID=
NYC_VENUES_DATABASE_ID=
# Google Workspace MCP (OAuth Desktop App - Brickocampus CLI)
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=
