<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.brickbot.watchdog</string>

    <key>ProgramArguments</key>
    <array>
        <string>__HOME__/projects/brickbot/scripts/heartbeat-watchdog.sh</string>
    </array>

    <!-- Every 5 minutes. Reads heartbeat ping files, alerts via iMessage on -->
    <!-- missing/stale pings or status=failed. Silent on success.            -->
    <key>StartInterval</key>
    <integer>300</integer>

    <key>StandardOutPath</key>
    <string>__HOME__/projects/brickbot/local/logs/watchdog-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/projects/brickbot/local/logs/watchdog-stderr.log</string>

    <key>WorkingDirectory</key>
    <string>__HOME__/projects/brickbot</string>
</dict>
</plist>
